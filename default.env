# The settings are in .env, use "nano .env". Don't edit default.env itself.
ENV_VERSION=1

# Compose files to use (colon-separated)
# Add :ext-network.yml for Traefik integration
# Add :rpc-shared.yml to expose RPC ports locally
COMPOSE_FILE=bittensor.yml

# Project name - used for container naming and Docker volume prefixes
PROJECT_NAME=bittensor

# Network: finney (mainnet) or test_finney (testnet)
NETWORK=finney

# Docker image
SUBTENSOR_DOCKER_REPO=ghcr.io/opentensor/subtensor
SUBTENSOR_DOCKER_TAG=latest

# Snapshot URL for initial sync (leave empty to sync from genesis)
# Supported formats: .tar.lz4, .tar.gz, .tar.zst, .tar
SNAPSHOT=

# Additional command-line flags passed to the subtensor binary
EXTRA_FLAGS=

# Pruning mode: archive or 256 (default substrate pruning)
PRUNING=archive

# Primary RPC port (HTTP + WebSocket on same port in Substrate)
RPC_PORT=9944

# Secondary HTTP RPC port (legacy, not actively used)
RPC_HTTP_PORT=9933

# P2P networking port
P2P_PORT=30333

# Logging: info, debug, warn, error, trace
LOG_LEVEL=info

# Secure web proxy - requires Traefik
DOMAIN=example.com
RPC_HOST=subtensor
RPC_LB=subtensor-lb
WS_HOST=subtensorws
WS_LB=subtensorws-lb

# External Docker network name for reverse proxy / monitoring
DOCKER_EXT_NETWORK=traefik_default

# Pin this repo to a specific git tag (leave empty for latest main)
SCRIPT_TAG=
